# rag-service 配置（复制为 .env 后修改）
# retriever: naive(零依赖, 开箱即跑) | semantic(语义向量检索, 需 OPENAI_API_KEY 做嵌入)
#   - semantic 模式用 DashScope /embeddings(text-embedding-v3) 生成向量 + 本地余弦检索
#   - 未配置 key 时自动降级为 naive 关键词检索，服务仍可启动
RETRIEVER=semantic
# llm: offline(无 key 也能跑, 规则拼接) | openai(真实大模型)
LLM_PROVIDER=openai

# 大模型（通义千问 DashScope 的 OpenAI 兼容接口）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# 向量嵌入模型（semantic 模式用，DashScope text-embedding-v3）
EMBEDDING_MODEL=text-embedding-v3

PORT=8000

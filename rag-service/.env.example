# rag-service 配置（复制为 .env 后修改）
# retriever: naive(零依赖, 开箱即跑) | chroma(生产, 需 pip install chromadb sentence-transformers)
RETRIEVER=naive
# llm: offline(无 key 也能跑, 规则拼接) | openai(真实大模型)
LLM_PROVIDER=offline

# 仅 LLM_PROVIDER=openai 时需要
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 仅 RETRIEVER=chroma 时需要
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

PORT=8000
